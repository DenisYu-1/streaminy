# Copy to .env and fill in your values
# docker-compose picks up .env from the project root automatically

# Your server's public IP address (required)
ANNOUNCED_IP=YOUR_PUBLIC_IP

# Room settings
ROOM_PASSWORD=change-me
ROOM_MAX_PARTICIPANTS=4

# mediasoup worker UDP port range (must be open in firewall)
WORKER_RTC_MIN_PORT=50000
WORKER_RTC_MAX_PORT=50200

# WebRTC transport port range
WEBRTC_MIN_PORT=50000
WEBRTC_MAX_PORT=50200

# TURN server credentials (leave TURN_SERVERS=[] to use Google STUN only)
TURN_USERNAME=your-turn-user
TURN_CREDENTIAL=your-turn-password
TURN_SERVERS=[]

ENABLE_UDP=true

# Grafana admin password
GF_ADMIN_PASSWORD=change-me
